NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime: "supabase" for hosted/shared state, "local" for file-backed local testing.
# If omitted, the app uses Supabase when the public Supabase env vars are present; otherwise it falls back to local mode.
BESIDE_YOU_RUNTIME=local

# Local testing auth
BESIDE_YOU_LOCAL_EMAIL=aspirant@beside-you.local
BESIDE_YOU_LOCAL_PASSWORD=beside-you-2026
BESIDE_YOU_LOCAL_NAME=Aspirant

# Supabase wiring
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
